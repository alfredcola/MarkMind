rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // GCS-only architecture: user can only access their own files
    // Files are stored at users/{userId}/documents/{filename} for documents
    // Companion data (chat, flashcards, MC) stored at users/{userId}/.metadata/{fileId}/

    match /users/{userId}/documents/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
      allow list: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/.metadata/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
      allow list: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
  }
}